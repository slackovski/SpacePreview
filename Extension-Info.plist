    <!-- ── Quick Look App Extension registration ────────────────────── -->
    <key>NSExtension</key>
    <dict>
        <key>NSExtensionAttributes</key>
        <dict>
            <key>QLIsDataBasedPreview</key>
            <true/>

            <key>QLSupportsSearchableItems</key>
            <false/>

            <key>QLSupportedContentTypes</key>
            <array>
                <!-- Generic fallback: Dockerfile, Makefile, .env and other
                     extensionless/unrecognised text files all get public.data.
                     PreviewProvider skips binary files via null-byte detection. -->
                <string>public.data</string>

                <!-- Web / Frontend -->
                <!-- .ts is mapped to MPEG-2 by macOS; we intercept it and check
                     the file extension in PreviewProvider to skip real video files -->
                <string>public.mpeg-2-transport-stream</string>
                <string>public.typescript-source</string>
                <string>com.netscape.javascript-source</string>
                <string>public.vue-source</string>
                <string>public.css</string>
                <string>public.scss-source</string>
                <string>public.less-source</string>
                <string>public.html</string>

